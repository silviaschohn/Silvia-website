---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

function slugify(title: string) {
  return title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
}

// Pull featured:true projects from every category collection into one list.
const imagineProjects = (await getCollection('imagine')).filter(p => p.data.featured)
  .map(p => ({ ...p.data, category: 'imagine', categoryLabel: 'Imagine' }));
const buildProjects = (await getCollection('build')).filter(p => p.data.featured)
  .map(p => ({ ...p.data, category: 'build', categoryLabel: 'Build' }));
const directProjects = (await getCollection('direct')).filter(p => p.data.featured)
  .map(p => ({ ...p.data, category: 'direct', categoryLabel: 'Direct' }));

const featured = [...imagineProjects, ...buildProjects, ...directProjects];
---
<BaseLayout title="Home">
  <Nav current="home" />

  <section class="hero">
    <svg class="hero-texture" viewBox="0 0 420 520" xmlns="http://www.w3.org/2000/svg">
      <g opacity="0.92">
        <path d="M235 210 C 300 190, 340 240, 320 300 C 300 355, 235 350, 210 300 C 190 250, 200 225, 235 210 Z" fill="#C9BBA5"/>
        <ellipse cx="262" cy="275" rx="42" ry="55" fill="#3E7FA8"/>
        <ellipse cx="262" cy="278" rx="20" ry="28" fill="#1C1A18"/>
        <ellipse cx="257" cy="266" rx="7" ry="9" fill="#F1EEE9" opacity="0.7"/>
        <g stroke="#C9BBA5" stroke-width="1.4" fill="none" opacity="0.65">
          <path d="M262 210 C 250 140, 270 90, 250 30"/>
          <path d="M290 218 C 300 150, 335 110, 340 55"/>
          <path d="M235 220 C 210 160, 175 130, 150 80"/>
          <path d="M300 250 C 350 230, 390 240, 410 200"/>
          <path d="M220 250 C 170 240, 130 260, 90 235"/>
        </g>
        <path d="M90 380 C 108 375, 118 392, 110 408 C 102 424, 80 424, 72 408 C 65 393, 74 384, 90 380 Z" fill="#1C1A18"/>
        <path d="M150 430 C 162 425, 172 436, 168 448 C 164 460, 148 462, 140 452 C 133 443, 140 434, 150 430 Z" fill="#7A2020"/>
        <path d="M55 300 C 65 296, 74 305, 70 316 C 67 326, 53 328, 47 319 C 42 311, 47 304, 55 300 Z" fill="#1C1A18"/>
        <path d="M330 380 C 340 376, 349 385, 345 396 C 341 406, 327 408, 321 399 C 316 391, 321 384, 330 380 Z" fill="#1C1A18"/>
        <path d="M370 320 C 378 317, 385 324, 382 332 C 379 340, 368 342, 363 334 C 359 328, 363 322, 370 320 Z" fill="#7A2020"/>
        <path d="M120 340 C 128 337, 135 344, 132 352 C 129 360, 118 362, 113 354 C 109 348, 113 342, 120 340 Z" fill="#1C1A18"/>
      </g>
    </svg>

    <div class="hero-inner">
      <img class="hero-logo" src="/images/logo/wordmark.jpg" alt="Silvia Schohn" />
      <p class="hero-tagline">Designing immersive worlds through story, craft, and artistic curiosity.</p>
    </div>

    <a class="scroll-cue" href="#featured">
      <span class="line"></span> See featured work
    </a>
  </section>

  <section id="featured" class="featured">
    <div class="featured-header">
      <span class="eyebrow">Featured</span>
    </div>

    <div class="featured-grid">
      {featured.map((project) => {
        const img = project.featuredImage || project.images[0];
        return (
          <a class="featured-card" href={`/${project.category}#${slugify(project.title)}`}>
            {img ? (
              <div class="featured-image" style={`background-image:url('/images/${project.category}/${project.imageFolder}/${img}')`}></div>
            ) : (
              <div class="featured-image featured-image-empty">Image coming soon</div>
            )}
          </a>
        );
      })}
    </div>

    <a class="see-all-work" href="/work">See all work &#8594;</a>
  </section>

  <Footer />
</BaseLayout>

<style>
  .hero{
    position:relative;
    min-height:100vh;
    display:flex;
    flex-direction:column;
    justify-content:center;
    padding:0 3rem;
    overflow:hidden;
  }
  .hero-inner{
    display:flex;
    flex-direction:column;
    align-items:flex-start;
    max-width:640px;
    margin-left:8vw;
    margin-top:2vh;
  }
  .hero-logo{
    width:min(560px, 62vw);
    opacity:0;
    transform:translateY(18px);
    animation:reveal 1.4s cubic-bezier(.19,1,.22,1) forwards;
    animation-delay:0.2s;
  }
  .hero-tagline{
    font-family:var(--serif);
    font-style:italic;
    font-weight:400;
    font-size:clamp(1rem, 1.6vw, 1.3rem);
    color:var(--ink);
    margin-top:1.6rem;
    margin-left:0.4rem;
    max-width:30ch;
    line-height:1.5;
    opacity:0;
    transform:translateY(12px);
    animation:reveal 1.2s cubic-bezier(.19,1,.22,1) forwards;
    animation-delay:0.9s;
  }
  @keyframes reveal{ to{opacity:1; transform:translateY(0);} }

  .scroll-cue{
    position:absolute;
    bottom:2.5rem; left:3rem;
    display:flex; align-items:center; gap:1rem;
    font-size:0.95rem;
    letter-spacing:0.1em;
    text-transform:uppercase;
    color:var(--ink);
    opacity:0.7;
    cursor:pointer;
    background:none; border:none;
    font-family:var(--sans);
    font-weight:500;
  }
  .scroll-cue .line{
    width:48px; height:1.5px; background:var(--ink);
    position:relative; overflow:hidden;
  }
  .scroll-cue .line::after{
    content:''; position:absolute; left:-100%; top:0;
    width:100%; height:100%; background:var(--maroon);
    animation:travel 2.2s ease-in-out infinite;
  }
  @keyframes travel{ 0%{left:-100%;} 50%{left:0;} 100%{left:100%;} }

  .hero-texture{
    position:absolute;
    right:12vw; top:2vh;
    width:26vw; max-width:380px;
    opacity:0.9;
    mix-blend-mode:multiply;
    animation:reveal 1.8s cubic-bezier(.19,1,.22,1) forwards;
    animation-delay:0.5s;
    opacity:0;
  }

  .featured{
    padding:2rem 3rem 6rem;
  }
  .featured-header{
    max-width:640px;
    margin-bottom:2rem;
  }
  .featured-header .eyebrow{
    font-size:0.72rem;
    letter-spacing:0.18em;
    text-transform:uppercase;
    color:var(--maroon);
    font-weight:500;
    display:block;
  }

  .featured-grid{
    display:grid;
    grid-template-columns:repeat(3, 1fr);
    gap:2rem;
    margin-bottom:2.5rem;
  }
  .featured-card{
    text-decoration:none;
    color:var(--ink);
    display:block;
  }
  .featured-image{
    width:100%;
    aspect-ratio:1/1;
    background-size:cover;
    background-position:center;
    filter:saturate(1.1) contrast(1.05);
    transition:transform 0.6s cubic-bezier(.19,1,.22,1), filter 0.4s ease;
  }
  .featured-card:hover .featured-image{
    transform:scale(1.02);
    filter:saturate(1.25) contrast(1.08);
  }
  .featured-image-empty{
    display:flex;
    align-items:center;
    justify-content:center;
    background:var(--sand);
    color:var(--ink);
    opacity:0.6;
    font-size:0.78rem;
    letter-spacing:0.08em;
    text-transform:uppercase;
    text-align:center;
    padding:1rem;
  }

  .see-all-work{
    display:inline-block;
    font-size:0.85rem;
    letter-spacing:0.08em;
    text-transform:uppercase;
    color:var(--ink);
    text-decoration:none;
    border-bottom:1px solid var(--ink);
    padding-bottom:2px;
    opacity:0.75;
    transition:opacity 0.3s ease;
  }
  .see-all-work:hover{opacity:1;}

  @media (max-width:800px){
    .hero{padding:0 1.4rem;}
    .hero-inner{margin-left:0;}
    .hero-texture{display:none;}
    .featured{padding:1rem 1.4rem 4rem;}
    .featured-grid{grid-template-columns:1fr; gap:2rem;}
  }
</style>
